# Copy to .env and fill in. NEVER commit your .env file.
# ---
# OFFLINE / LOCAL DEMO MODE: set MONK_MODEL=fake (and optionally MONK_EMBEDDINGS=fake)
# to run every lab against a deterministic stand-in - useful when Bedrock / Vertex
# access is still pending the day before class.
# ---

# --- AWS ---
AWS_REGION=us-east-1
# Optional: if not set, boto3 reads ~/.aws/credentials (preferred for the bootcamp).
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- GCP ---
GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=us-central1
# Optional: a Cloud Storage bucket for Vertex Agent Engine staging.
# Created by ./scripts/setup_gcp.sh as gs://<project>-monk-staging
GCP_BUCKET=your-gcp-project-id-monk-staging

# --- Model selection (we change MONK_MODEL per lab) ---
# Default for Days 1-6 is OpenAI's open-weight gpt-oss-120b hosted on Bedrock.
# No use-case form, no inference-profile prefix - just request model access in
# the Bedrock console and you're in. Day 4 deploy uses Vertex Gemini.
MONK_MODEL=bedrock_converse:openai.gpt-oss-120b-1:0
# To switch:
#   MONK_MODEL=google_vertexai:gemini-2.5-pro
#   MONK_MODEL=bedrock_converse:openai.gpt-oss-20b-1:0    # smaller + cheaper

# Embeddings for RAG (Day 2+)
MONK_EMBEDDINGS=bedrock:amazon.titan-embed-text-v2:0
# Alt: MONK_EMBEDDINGS=google_vertexai:text-embedding-005

# --- Tavily (web search tool) ---
TAVILY_API_KEY=tvly-your-key

# --- LangSmith (observability + evals) ---
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_your-key
LANGSMITH_PROJECT=monk-bootcamp-yourname

# --- Postgres (pgvector, runs in Docker locally) ---
# Docker maps host port 5433 -> container port 5432, so we don't collide with
# any Postgres you may already have installed on 5432 (Homebrew, system, etc.).
POSTGRES_DSN=postgresql://postgres:postgres@localhost:5433/monk

# --- Optional, set after Day 4 ---
# BEDROCK_GUARDRAIL_ID=
# BEDROCK_GUARDRAIL_VERSION=DRAFT
# VERTEX_MODEL_ARMOR_POLICY=
